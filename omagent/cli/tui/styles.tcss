/* omagent TUI Stylesheet */

Screen {
    background: $surface;
}

Header {
    dock: top;
    background: $primary;
    color: $text;
}

Footer {
    dock: bottom;
}

#main-container {
    height: 1fr;
}

#chat-panel {
    width: 1fr;
}

#chat-view {
    height: 1fr;
    border: none;
    scrollbar-size: 1 1;
}

#message-input {
    dock: bottom;
    height: 3;
    margin: 0 1;
    border: tall $accent;
}

#message-input:focus {
    border: tall $primary;
}

#sidebar {
    width: 35;
    border-left: tall $surface-lighten-2;
    padding: 1;
    overflow-y: auto;
}

#sidebar.hidden {
    display: none;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: $primary-darken-2;
    color: $text;
    padding: 0 1;
}

/* Chat message styles */
.user-message {
    background: $primary-darken-3;
    margin: 0 1 1 1;
    padding: 1;
    border: round $primary-darken-1;
}

.assistant-message {
    margin: 0 1 1 1;
    padding: 1;
}

.system-message {
    color: $text-muted;
    margin: 0 1 1 1;
    padding: 0 1;
}

.error-message {
    color: $error;
    background: $error 10%;
    margin: 0 1 1 1;
    padding: 1;
    border: round $error;
}

.tool-call {
    color: $accent;
    margin: 0 1 0 3;
    padding: 0 1;
}

.tool-result {
    color: $text-muted;
    margin: 0 1 1 3;
    padding: 0 1;
}

.tool-result-error {
    color: $error;
    margin: 0 1 1 3;
    padding: 0 1;
}

/* Sidebar sections */
.sidebar-section {
    margin-bottom: 1;
}

.sidebar-title {
    text-style: bold;
    color: $accent;
    margin-bottom: 0;
}

.sidebar-value {
    color: $text;
    margin-left: 1;
}

.sidebar-tool-item {
    color: $text-muted;
    margin-left: 1;
}
