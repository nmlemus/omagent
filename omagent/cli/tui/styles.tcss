/* === omagent TUI — Material Design 3 Terminal Theme === */

Screen {
    background: #1a1a2e;
    color: #e0e0e6;
}

Header {
    dock: top;
    background: #16162a;
    color: #a8b4f0;
}

Footer {
    dock: bottom;
    background: #16162a;
}

#main-container {
    height: 1fr;
}

#chat-panel {
    width: 1fr;
}

#chat-view {
    height: 1fr;
    scrollbar-size: 1 1;
}

/* === Message Cards === */
.message-card {
    margin: 0 1 1 1;
    padding: 1 2;
    height: auto;
}

.message-card-user {
    border-left: thick #a8b4f0;
}

.message-card-assistant {
    border-left: thick #80cbc4;
}

.message-card-system {
    color: #9898a8;
    padding: 0 2;
    margin: 0 1;
}

.message-card-error {
    border-left: thick #ef9a9a;
    background: #2a1a1a;
}

.message-label {
    height: auto;
}

.message-content {
    height: auto;
    margin-top: 0;
}

/* === Tool Cards === */
.tool-card {
    margin: 1 2 1 4;
    border: round #3a3a50;
    background: #232340;
    height: auto;
}

.tool-card-header {
    height: 1;
    padding: 0 1;
    background: #16162a;
    color: #9898a8;
}

.tool-card-input {
    padding: 1 2;
    height: auto;
    border-bottom: solid #2e2e42;
}

.tool-card-output {
    padding: 1 2;
    height: auto;
    color: #9898a8;
}

.tool-card-error {
    border: round #ef9a9a;
}

/* === Thinking Indicator === */
.thinking-indicator {
    color: #ffe082;
    padding: 0 2;
    margin: 0 1;
    height: auto;
}

/* === Round Separator === */
.round-separator {
    height: 1;
    color: #a8b4f0;
    margin: 1 1 0 1;
}

/* === Step Progress === */
.step-progress {
    color: #9898a8;
    padding: 0 2;
    margin: 0 1;
    height: auto;
}

/* === Status Bar === */
StatusBar {
    dock: bottom;
    height: 1;
    background: #16162a;
    color: #9898a8;
    layout: horizontal;
}

.status-segment {
    height: 1;
    padding: 0 1;
    width: auto;
    content-align: left middle;
}

.status-indicator-active {
    color: #ffe082;
}

.status-indicator-ready {
    color: #a5d6a7;
}

/* === Input Area === */
#message-input {
    dock: bottom;
    height: 3;
    margin: 0 1;
    border: tall #3a3a50;
    background: #232340;
    color: #e0e0e6;
}

#message-input:focus {
    border: tall #a8b4f0;
}

/* === Sidebar === */
#sidebar {
    width: 30;
    border-left: solid #2e2e42;
    padding: 1;
    background: #16162a;
    overflow-y: auto;
}

#sidebar.hidden {
    display: none;
}

.sidebar-title {
    color: #a8b4f0;
    text-style: bold;
    margin-bottom: 0;
}

.sidebar-value {
    color: #e0e0e6;
    margin-left: 1;
    height: auto;
}

.sidebar-tool-item {
    color: #9898a8;
    margin-left: 1;
    height: auto;
}

/* === Activity Log === */
#activity-log {
    height: 8;
    border-top: solid #3a3a50;
    background: #16162a;
    padding: 0 1;
    overflow-y: auto;
}

#activity-log.hidden {
    display: none;
}

.activity-entry {
    color: #9898a8;
    height: 1;
}

/* === Markdown Content === */
.message-content-md {
    height: auto;
    margin: 0;
    padding: 0;
}

Markdown {
    height: auto;
    margin: 0;
    padding: 0;
}

MarkdownH1 {
    color: #a8b4f0;
    text-style: bold;
    margin: 1 0 0 0;
}

MarkdownH2 {
    color: #80cbc4;
    text-style: bold;
    margin: 1 0 0 0;
}

MarkdownH3 {
    color: #ce93d8;
    text-style: bold;
    margin: 1 0 0 0;
}

MarkdownFence {
    background: #232340;
    margin: 1 0;
    padding: 1 2;
    border: round #3a3a50;
}

MarkdownBlockQuote {
    border-left: thick #3a3a50;
    padding-left: 2;
    color: #9898a8;
}

MarkdownBulletList {
    margin: 0 0 0 2;
}

MarkdownOrderedList {
    margin: 0 0 0 2;
}

MarkdownTable {
    margin: 1 0;
}

/* === Splash Screen === */
SplashScreen {
    height: auto;
    margin: 0 1 1 1;
    padding: 0;
}

/* ensure all direct children of ChatView size to content */
ChatView > * {
    height: auto;
}
