# LLM Provider (litellm compatible)
OMAGENT_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Server
OMAGENT_HOST=0.0.0.0
OMAGENT_PORT=8000

# Domain pack (default)
OMAGENT_PACK=data_science

# Sessions DB
OMAGENT_DB_PATH=~/.omagent/sessions.db

# Permissions: auto | prompt | deny
OMAGENT_DEFAULT_PERMISSION=prompt
